  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "daisyui": "^4.12.24",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.10",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^12.1.5",
    "standard": "^17.1.2",
    "tailwindcss": "^3.4.19"
  },
  "engines": {
    "node": "^24"
  },
  "packageManager": "yarn@4.13.0"
}
