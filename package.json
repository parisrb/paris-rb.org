{
  "name": "app",
  "private": true,
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "debounced": "^1.0.2",
    "lite-youtube-embed": "^0.3.4",
    "rfs": "^10.0.0",
    "stimulus-use": "^0.52.3"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
